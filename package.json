{
  "name": "nestly",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev -w @nestly/web",
    "build": "npm run build -w @nestly/web",
    "lint": "npm run lint -w @nestly/shared && npm run lint -w @nestly/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mobile": "npm test -w @nestly/mobile",
    "dev:mobile": "npm run start -w @nestly/mobile",
    "version:patch": "node scripts/version-bump.mjs patch",
    "version:minor": "node scripts/version-bump.mjs minor",
    "version:major": "node scripts/version-bump.mjs major"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.2",
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0",
    "resend": "^6.9.3"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
