rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAuthor(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    function validImageType() {
      return request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function validVideoType() {
      return request.resource.contentType.matches('video/(mp4|quicktime)');
    }

    function underImageSize() {
      return request.resource.size <= 10 * 1024 * 1024;
    }

    function underVideoSize() {
      return request.resource.size <= 30 * 1024 * 1024;
    }

    match /village/{nestId}/{authorUid}/{postId}/{filename} {
      allow read:   if isAuthenticated();
      allow create: if isAuthor(authorUid)
                    && ((validImageType() && underImageSize())
                        || (validVideoType() && underVideoSize()));
      allow delete: if isAuthor(authorUid);
      allow update: if false;
    }
  }
}
