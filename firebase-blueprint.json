{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "profileData": { "type": "string", "description": "JSON stringified profile data" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "UserLog": {
      "title": "UserLog",
      "description": "User activity logs",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "logData": { "type": "string", "description": "JSON stringified log data" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/user_logs/{userId}": {
      "schema": { "$ref": "#/entities/UserLog" },
      "description": "User activity logs"
    }
  }
}
