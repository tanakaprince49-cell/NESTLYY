{
  "expo": {
    "name": "Nestly",
    "slug": "nestly",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nestly",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdf8f7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nestly.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fdf8f7"
      },
      "package": "com.nestly.app"
    },
    "plugins": [
      "expo-splash-screen"
    ]
  }
}
