{
  "name": "Nestly Pregnancy Companion",
  "short_name": "Nestly",
  "description": "Premium pregnancy nutrition and wellness tracker.",
  "id": "com.nestly.app.v10",
  "start_url": "/?pwa=true",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#ffffff",
  "theme_color": "#7e1631",
  "icons": [
    {
      "src": "/logo.webp",
      "sizes": "192x192",
      "type": "image/webp",
      "purpose": "any"
    },
    {
      "src": "/logo.webp",
      "sizes": "512x512",
      "type": "image/webp",
      "purpose": "any"
    },
    {
      "src": "/logo.webp",
      "sizes": "512x512",
      "type": "image/webp",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Log Tools",
      "short_name": "Tools",
      "url": "/?tab=tools",
      "description": "Log weight, sleep, or contractions",
      "icons": [{ "src": "/logo.webp", "sizes": "192x192" }]
    }
  ],
  "widgets": [
    {
      "name": "Nestly Glance",
      "short_name": "Glance",
      "description": "View your pregnancy progress.",
      "tag": "nestly-stats",
      "template": "nestly-stats-template",
      "ms_ac_template": "nestly-widget-adaptive-card.json",
      "icons": [
        {
          "src": "/logo.webp",
          "sizes": "192x192",
          "type": "image/webp"
        }
      ]
    }
  ],
  "orientation": "portrait",
  "prefer_related_applications": false
}